default_profile = '{{ if .work }}work-direct{{ else }}personal-direct{{ end }}'

[compaction]
threshold_pct = 75

[[modes]]
color = '#8995A8'
description = 'Balanced — routes work, delegates to subagents'
name = 'smart'
prompt = 'file:prompts/smart.md'
reasoning = 'medium'

[[modes]]
color = '#C75B7A'
description = 'Fast local edits, minimal verification'
name = 'rush'
prompt = 'file:prompts/rush.md'

[[modes]]
color = '#D4A76A'
description = 'Complex multi-step, high reasoning'
name = 'deep'
prompt = 'file:prompts/deep.md'
reasoning = 'high'

[notifications]
enabled = true
permission_ask = true
turn_complete = false

[permission]
file_read_outside_pwd = 'ask'
file_write = 'allow'
mcp = 'allow'
network = 'ask'
shell = 'allow'
subagent = 'allow'

[plugins]
sources = ['github:cfbender/quorum', 'github:cfbender/cesium']

[subagents]
[subagents.carpenter]
description = 'Spec/plan implementer — writes code from specs'
prompt = 'file:prompts/carpenter.md'

[subagents.librarian]
description = 'External reference and documentation specialist'
prompt = 'file:prompts/librarian.md'
tools = ['file_read', 'bash', 'grep']

[subagents.oracle]
description = 'Senior technical advisor for hard decisions'
prompt = 'file:prompts/oracle.md'
tools = ['file_read', 'grep', 'glob']

[subagents.review]
description = 'Bug identification and code review assistance'
prompt = 'file:prompts/review.md'
tools = ['file_read', 'grep', 'glob', 'bash']

[subagents.search]
description = 'Read-only codebase locator'
prompt = 'file:prompts/search.md'
tools = ['file_read', 'grep', 'glob', 'bash']

[ui]
nerd_fonts = true
