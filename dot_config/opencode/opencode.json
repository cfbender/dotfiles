{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-agent-skills", "@tarquinen/opencode-dcp@latest"],
  "default_agent": "smart",
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/smart.md}",
      "color": "#7287fd"
    },
    "rush": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "{file:./prompts/rush.md}",
      "color": "#dd7878"
    },
    "deep": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
      "color": "#8839ef"
    },
    "search": {
      "mode": "subagent",
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  }
}
