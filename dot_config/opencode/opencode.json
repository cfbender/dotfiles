{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/build.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/plan.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "general": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/general.md}"
    }
  }
}
