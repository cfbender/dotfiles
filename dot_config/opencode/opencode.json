{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-handoff", "opencode-agent-skills", "@tarquinen/opencode-dcp@latest"],
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/smart.md}",
    },
    "rush": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "{file:./prompts/rush.md}"
    },
    "deep": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
    },
    "search": {
      "mode": "subagent",
      "model": "google/gemini-3-flash-preview",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "*": "ask",
        "edit": "deny",
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "*": "ask",
        "edit": "deny",
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "*": "ask",
        "edit": "deny",
      }
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
  },
  "command": {
    "review": {
      "template": "{file:./commands/review.md}",
      "description": "review changes [commit|branch|pr], defaults to uncommitted",
      "subtask": true,
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  }
}
