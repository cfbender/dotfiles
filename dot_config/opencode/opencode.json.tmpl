{{- $models := splitList "\n" (trim (output "opencode" "models")) -}}
{{- $useOpenRouter := .useOpenRouter -}}
{{- $work := .work -}}

{{- /* Declare model variables with defaults (opencode-go for personal) */ -}}
{{- $smartModel := "opencode-go/deepseek-v4-pro" -}}
{{- $rushModel := "opencode-go/deepseek-v4-flash" -}}
{{- $deepModel := "opencode-go/mimo-v2.5-pro" -}}
{{- $searchModel := "opencode-go/deepseek-v4-flash" -}}
{{- $oracleModel := "opencode-go/qwen3.6-plus" -}}
{{- $librarianModel := "opencode-go/kimi-k2.6" -}}
{{- $carpenterModel := "opencode-go/mimo-v2.5-pro" -}}

{{- if $work -}}
  {{- /* Work: github-copilot defaults, upgrade if openrouter/direct available */ -}}
  {{- $smartModel = "github-copilot/claude-opus-4.6" -}}
  {{- $rushModel = "github-copilot/claude-haiku-4.5" -}}
  {{- $deepModel = "github-copilot/gpt-5.3-codex" -}}
  {{- $searchModel = "github-copilot/gemini-3-flash-preview" -}}
  {{- $oracleModel = "github-copilot/gpt-5.4" -}}
  {{- $librarianModel = "github-copilot/claude-sonnet-4.6" -}}
  {{- $carpenterModel = "github-copilot/claude-sonnet-4.6" -}}

  {{- if $useOpenRouter -}}
    {{- if has "openrouter/anthropic/claude-opus-4.7" $models -}}{{- $smartModel = "openrouter/anthropic/claude-opus-4.7" -}}
    {{- else if has "openrouter/anthropic/claude-opus-4.6" $models -}}{{- $smartModel = "openrouter/anthropic/claude-opus-4.6" -}}{{- end -}}
    {{- if has "openrouter/anthropic/claude-haiku-4.5" $models -}}{{- $rushModel = "openrouter/anthropic/claude-haiku-4.5" -}}{{- end -}}
    {{- if has "openrouter/openai/gpt-5.3-codex" $models -}}{{- $deepModel = "openrouter/openai/gpt-5.3-codex" -}}{{- end -}}
    {{- if has "openrouter/google/gemini-3-flash-preview" $models -}}{{- $searchModel = "openrouter/google/gemini-3-flash-preview" -}}{{- end -}}
    {{- if has "openrouter/openai/gpt-5.4" $models -}}{{- $oracleModel = "openrouter/openai/gpt-5.4" -}}{{- end -}}
    {{- if has "openrouter/anthropic/claude-sonnet-4.6" $models -}}{{- $librarianModel = "openrouter/anthropic/claude-sonnet-4.6" -}}{{- $carpenterModel = "openrouter/anthropic/claude-sonnet-4.6" -}}{{- end -}}
  {{- else -}}
    {{- if has "anthropic/claude-opus-4-7" $models -}}{{- $smartModel = "anthropic/claude-opus-4-7" -}}
    {{- else if has "anthropic/claude-opus-4-6" $models -}}{{- $smartModel = "anthropic/claude-opus-4-6" -}}{{- end -}}
    {{- if has "anthropic/claude-haiku-4-5" $models -}}{{- $rushModel = "anthropic/claude-haiku-4-5" -}}{{- end -}}
    {{- if has "openai/gpt-5.3-codex" $models -}}{{- $deepModel = "openai/gpt-5.3-codex" -}}{{- end -}}
    {{- if has "openai/gpt-5.4" $models -}}{{- $oracleModel = "openai/gpt-5.4" -}}{{- end -}}
    {{- if has "anthropic/claude-sonnet-4-6" $models -}}{{- $librarianModel = "anthropic/claude-sonnet-4-6" -}}{{- $carpenterModel = "anthropic/claude-sonnet-4-6" -}}{{- end -}}
  {{- end -}}
{{- else -}}
  {{- /* Personal: nvidia defaults already set, upgrade if openrouter enabled */ -}}
  {{- if $useOpenRouter -}}
    {{- if has "openrouter/anthropic/claude-opus-4.7" $models -}}{{- $smartModel = "openrouter/anthropic/claude-opus-4.7" -}}
    {{- else if has "openrouter/anthropic/claude-opus-4.6" $models -}}{{- $smartModel = "openrouter/anthropic/claude-opus-4.6" -}}{{- end -}}
    {{- if has "openrouter/anthropic/claude-haiku-4.5" $models -}}{{- $rushModel = "openrouter/anthropic/claude-haiku-4.5" -}}{{- end -}}
    {{- if has "openrouter/openai/gpt-5.3-codex" $models -}}{{- $deepModel = "openrouter/openai/gpt-5.3-codex" -}}{{- end -}}
    {{- if has "openrouter/google/gemini-3-flash-preview" $models -}}{{- $searchModel = "openrouter/google/gemini-3-flash-preview" -}}{{- end -}}
    {{- if has "openrouter/openai/gpt-5.4" $models -}}{{- $oracleModel = "openrouter/openai/gpt-5.4" -}}{{- end -}}
    {{- if has "openrouter/anthropic/claude-sonnet-4.6" $models -}}{{- $librarianModel = "openrouter/anthropic/claude-sonnet-4.6" -}}{{- $carpenterModel = "openrouter/anthropic/claude-sonnet-4.6" -}}{{- end -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@tarquinen/opencode-dcp@latest", "quorum@git+https://github.com/cfbender/quorum.git"],
  "default_agent": "smart",
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "{{ $smartModel }}",
      "prompt": "{file:./prompts/smart.md}",
      "color": "#8995A8",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "rush": {
      "mode": "primary",
      "model": "{{ $rushModel }}",
      "prompt": "{file:./prompts/rush.md}",
      "color": "#C75B7A",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "deep": {
      "mode": "primary",
      "model": "{{ $deepModel }}",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
      "color": "#D4A76A",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "search": {
      "mode": "subagent",
      "model": "{{ $searchModel }}",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "{{ $oracleModel }}",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "{{ $librarianModel }}",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "carpenter": {
      "mode": "subagent",
      "model": "{{ $carpenterModel }}",
      "prompt": "{file:./prompts/carpenter.md}"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://10.0.69.239:11434/v1"
      },
      "models": {
        "gemma4": {
          "name": "Gemma 4",
          "tools": true
        }
      }
    }
  }
}
