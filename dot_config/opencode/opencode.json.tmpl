{{- $models := splitList "\n" (trim (output "opencode" "models")) -}}
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-agent-skills", "@tarquinen/opencode-dcp@latest", "superpowers@git+https://github.com/obra/superpowers.git"],
  "default_agent": "smart",
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "{{- if has "openrouter/anthropic/claude-opus-4.7" $models -}}openrouter/anthropic/claude-opus-4.7{{- else if has "anthropic/claude-opus-4-7" $models -}}anthropic/claude-opus-4-7{{- else if has "openrouter/anthropic/claude-opus-4.6" $models -}}openrouter/anthropic/claude-opus-4.6{{- else if has "anthropic/claude-opus-4-6" $models -}}anthropic/claude-opus-4-6{{- else -}}github-copilot/claude-opus-4.6{{- end -}}",
      "prompt": "{file:./prompts/smart.md}",
      "color": "#74c7ec"
    },
    "rush": {
      "mode": "primary",
      "model": "{{- if has "openrouter/anthropic/claude-haiku-4.5" $models -}}openrouter/anthropic/claude-haiku-4.5{{- else if has "anthropic/claude-haiku-4-5" $models -}}anthropic/claude-haiku-4-5{{- else -}}github-copilot/claude-haiku-4.5{{- end -}}",
      "prompt": "{file:./prompts/rush.md}",
      "color": "#f38ba8"
    },
    "deep": {
      "mode": "primary",
      "model": "{{- if has "openrouter/openai/gpt-5.3-codex" $models -}}openrouter/openai/gpt-5.3-codex{{- else if has "openai/gpt-5.3-codex" $models -}}openai/gpt-5.3-codex{{- else -}}github-copilot/gpt-5.3-codex{{- end -}}",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
      "color": "#cba6f7"
    },
    "search": {
      "mode": "subagent",
      "model": "{{- if has "openrouter/google/gemini-3-flash-preview" $models -}}openrouter/google/gemini-3-flash-preview{{- else -}}github-copilot/gemini-3-flash-preview{{- end -}}",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "{{- if has "openrouter/openai/gpt-5.4" $models -}}openrouter/openai/gpt-5.4{{- else if has "openai/gpt-5.4" $models -}}openai/gpt-5.4{{- else -}}github-copilot/gpt-5.4{{- end -}}",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "{{- if has "openrouter/anthropic/claude-sonnet-4.6" $models -}}openrouter/anthropic/claude-sonnet-4.6{{- else if has "anthropic/claude-sonnet-4-6" $models -}}anthropic/claude-sonnet-4-6{{- else -}}github-copilot/claude-sonnet-4.6{{- end -}}",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://10.0.69.239:11434/v1"
      },
      "models": {
        "gemma4": {
          "name": "Gemma 4",
          "tools": true
        }
      }
    }
  }
}
