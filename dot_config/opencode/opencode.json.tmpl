{{- $useOpenRouter := .useOpenRouter -}}
{{- $work := .work -}}

{{- /* Per-branch agent model selection. Each branch is self-contained. */ -}}
{{- $smartModel := "" -}}
{{- $rushModel := "" -}}
{{- $deepModel := "" -}}
{{- $searchModel := "" -}}
{{- $oracleModel := "" -}}
{{- $librarianModel := "" -}}
{{- $carpenterModel := "" -}}

{{- if $work -}}
  {{- if $useOpenRouter -}}
    {{- $smartModel     = "openrouter/anthropic/claude-opus-4.7"      -}}
    {{- $rushModel      = "openrouter/anthropic/claude-haiku-4.5"     -}}
    {{- $deepModel      = "openrouter/openai/gpt-5.3-codex"           -}}
    {{- $searchModel    = "openrouter/google/gemini-3-flash-preview"  -}}
    {{- $oracleModel    = "openrouter/openai/gpt-5.4"                 -}}
    {{- $librarianModel = "openrouter/anthropic/claude-sonnet-4.6"    -}}
    {{- $carpenterModel = "openrouter/anthropic/claude-sonnet-4.6"    -}}
  {{- else -}}
    {{- $smartModel     = "anthropic/claude-opus-4-7"                 -}}
    {{- $rushModel      = "anthropic/claude-haiku-4-5"                -}}
    {{- $deepModel      = "openai/gpt-5.3-codex"                      -}}
    {{- $searchModel    = "openai/gpt-5.4-nano"                      -}}
    {{- $oracleModel    = "openai/gpt-5.4"                            -}}
    {{- $librarianModel = "anthropic/claude-sonnet-4-6"               -}}
    {{- $carpenterModel = "anthropic/claude-sonnet-4-6"               -}}
  {{- end -}}
{{- else -}}
  {{- if $useOpenRouter -}}
    {{- $smartModel     = "openrouter/anthropic/claude-sonnet-4.6"    -}}
    {{- $rushModel      = "openrouter/anthropic/claude-haiku-4.5"     -}}
    {{- $deepModel      = "openrouter/openai/gpt-5.4"                 -}}
    {{- $searchModel    = "openrouter/google/gemini-3-flash-preview"  -}}
    {{- $oracleModel    = "openrouter/openai/gpt-5.4"                 -}}
    {{- $librarianModel = "openrouter/anthropic/claude-haiku-4.5"     -}}
    {{- $carpenterModel = "openrouter/anthropic/claude-haiku-4.5"     -}}
  {{- else -}}
    {{- $smartModel     = "opencode-go/deepseek-v4-pro"               -}}
    {{- $rushModel      = "opencode-go/deepseek-v4-flash"             -}}
    {{- $deepModel      = "opencode-go/mimo-v2.5-pro"                 -}}
    {{- $searchModel    = "opencode-go/deepseek-v4-flash"             -}}
    {{- $oracleModel    = "opencode-go/qwen3.6-plus"                  -}}
    {{- $librarianModel = "opencode-go/kimi-k2.6"                     -}}
    {{- $carpenterModel = "opencode-go/mimo-v2.5-pro"                 -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@tarquinen/opencode-dcp@latest", "quorum@git+https://github.com/cfbender/quorum.git"],
  "default_agent": "smart",
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "{{ $smartModel }}",
      "prompt": "{file:./prompts/smart.md}",
      "color": "#8995A8",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "rush": {
      "mode": "primary",
      "model": "{{ $rushModel }}",
      "prompt": "{file:./prompts/rush.md}",
      "color": "#C75B7A",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "deep": {
      "mode": "primary",
      "model": "{{ $deepModel }}",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
      "color": "#D4A76A",
      "permission": {
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        },
        "external_directory": {
          "/tmp/**": "allow"
        }
      }
    },
    "search": {
      "mode": "subagent",
      "model": "{{ $searchModel }}",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "{{ $oracleModel }}",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "{{ $librarianModel }}",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "carpenter": {
      "mode": "subagent",
      "model": "{{ $carpenterModel }}",
      "prompt": "{file:./prompts/carpenter.md}"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://10.0.69.239:11434/v1"
      },
      "models": {
        "gemma4": {
          "name": "Gemma 4",
          "tools": true
        }
      }
    }
  }
}
