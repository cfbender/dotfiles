{{- $models := splitList "\n" (trim (output "opencode" "models")) -}}
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-agent-skills", "@tarquinen/opencode-dcp@latest"],
  "default_agent": "smart",
  "agent": {
    "smart": {
      "mode": "primary",
      "model": "{{- if has "anthropic/claude-opus-4-6" $models -}}anthropic/claude-opus-4-6{{- else if has "github-copilot/claude-opus-4.6" $models -}}github-copilot/claude-opus-4.6{{- else -}}anthropic/claude-opus-4-6{{- end -}}",
      "prompt": "{file:./prompts/smart.md}",
      "color": "#74c7ec"
    },
    "rush": {
      "mode": "primary",
      "model": "{{- if has "anthropic/claude-haiku-4-5" $models -}}anthropic/claude-haiku-4-5{{- else if has "github-copilot/claude-haiku-4.5" $models -}}github-copilot/claude-haiku-4.5{{- else -}}anthropic/claude-haiku-4-5{{- end -}}",
      "prompt": "{file:./prompts/rush.md}",
      "color": "#f38ba8"
    },
    "deep": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/deep.md}",
      "reasoningEffort": "xhigh",
      "color": "#cba6f7"
    },
    "search": {
      "mode": "subagent",
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt": "{file:./prompts/search.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "oracle": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "prompt": "{file:./prompts/oracle.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "{{- if has "anthropic/claude-sonnet-4-6" $models -}}anthropic/claude-sonnet-4-6{{- else if has "github-copilot/claude-sonnet-4.6" $models -}}github-copilot/claude-sonnet-4.6{{- else -}}anthropic/claude-sonnet-4-6{{- end -}}",
      "prompt": "{file:./prompts/librarian.md}",
      "permission": {
        "edit": "deny",
      }
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  }
}
