{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "smart": { "model": "openai/gpt-5.5", "reasoningEffort": "high" },
    "rush": { "model": "openai/gpt-5.4-mini" },
    "deep": { "model": "openai/gpt-5.5" },
    "search": { "model": "openai/gpt-5.4-mini" },
    "oracle": { "model": "openai/gpt-5.4" },
    "librarian": { "model": "openai/gpt-5.4" },
    "carpenter": { "model": "openai/gpt-5.5", "reasoningEffort": "low" }
  }
}
