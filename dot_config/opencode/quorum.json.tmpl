{
  "$schema": "https://raw.githubusercontent.com/cfbender/quorum/main/schema.json",
  "members": [
{{- range $i, $m := $members }}{{ if $i }},{{ end }}
    {
      "name": "{{ $m.name }}",
      "providerID": "{{ $m.providerID }}",
      "modelID": "{{ $m.modelID }}",
      "label": "{{ $m.label }}"
    }
{{- end }}
  ],
  "deepMembers": [
{{- range $i, $m := $deepMembers }}{{ if $i }},{{ end }}
    {
      "name": "{{ $m.name }}",
      "providerID": "{{ $m.providerID }}",
      "modelID": "{{ $m.modelID }}",
      "label": "{{ $m.label }}",
      "reasoningEffort": "xhigh"
    }
{{- end }}
  ],
  "triggerMode": "auto",
  "specDir": "docs/quorum/specs"
}
