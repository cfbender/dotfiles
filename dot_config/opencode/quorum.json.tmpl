{{- $useOpenRouter := .useOpenRouter -}}
{{- $work := .work -}}

{{- /* Build members + deepMembers per branch. */ -}}
{{- $members := list -}}
{{- $deepMembers := list -}}

{{- if $work -}}
  {{- if $useOpenRouter -}}
    {{- $members = list
      (dict "name" "quorum-opus-4.7"       "providerID" "openrouter" "modelID" "anthropic/claude-opus-4.7"     "label" "opus-4.7")
      (dict "name" "quorum-gpt-5.5"        "providerID" "openrouter" "modelID" "openai/gpt-5.5"                "label" "gpt-5.5")
      (dict "name" "quorum-gemini-3.1-pro" "providerID" "openrouter" "modelID" "google/gemini-3.1-pro-preview" "label" "gemini-3.1-pro")
    -}}
  {{- else -}}
    {{- $members = list
      (dict "name" "quorum-gpt-5.3-codex"  "providerID" "openai"     "modelID" "gpt-5.3-codex"                 "label" "gpt-5.3-codex")
      (dict "name" "quorum-opus-4.7"       "providerID" "anthropic"  "modelID" "claude-opus-4.7"               "label" "opus-4.7")
      (dict "name" "quorum-gpt-5.5"        "providerID" "openai"     "modelID" "gpt-5.5"                       "label" "gpt-5.5")
    -}}
  {{- end -}}
{{- else -}}
  {{- if $useOpenRouter -}}
    {{- $members = list
      (dict "name" "quorum-sonnet-4.6"     "providerID" "openrouter" "modelID" "anthropic/claude-sonnet-4.6"   "label" "sonnet-4.6")
      (dict "name" "quorum-gpt-5.4"        "providerID" "openrouter" "modelID" "openai/gpt-5.4"                "label" "gpt-5.4")
      (dict "name" "quorum-gemini-3-flash" "providerID" "openrouter" "modelID" "google/gemini-3-flash-preview" "label" "gemini-3-flash")
    -}}
  {{- else -}}
    {{- $members = list
      (dict "name" "quorum-deepseek-v4-pro"  "providerID" "opencode-go" "modelID" "deepseek-v4-pro"               "label" "deepseek-v4-pro")
      (dict "name" "quorum-mimo-v2.5-pro"    "providerID" "opencode-go" "modelID" "mimo-v2.5-pro"                 "label" "mimo-v2.5-pro")
      (dict "name" "quorum-qwen3.6-plus"     "providerID" "opencode-go" "modelID" "qwen3.6-plus"                  "label" "qwen3.6-plus")
    -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://raw.githubusercontent.com/cfbender/quorum/main/schema.json",
  "members": [
{{- range $i, $m := $members }}{{ if $i }},{{ end }}
    {
      "name": "{{ $m.name }}",
      "providerID": "{{ $m.providerID }}",
      "modelID": "{{ $m.modelID }}",
      "label": "{{ $m.label }}"
    }
{{- end }}
  ],
  "triggerMode": "auto",
  "specDir": "docs/quorum/specs"
}
