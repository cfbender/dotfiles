{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "dBg": "#180E10",
    "dBgSoft": "#211618",
    "dBgMute": "#2B1F22",
    "dDivider": "#3A2E25",
    "dText": "#DDD3C7",
    "dText3": "#9E9288",
    "dText4": "#71685E",
    "dRose1": "#C75B7A",
    "dRose2": "#B04A68",
    "dGold1": "#D4A76A",
    "dGold2": "#C5975B",
    "dSage1": "#8FA86E",
    "dSage2": "#7A9460",
    "dType1": "#8995A8",
    "dTerra1": "#C44536",
    "lBg": "#FDF8F3",
    "lBgSoft": "#F5EDE3",
    "lBgMute": "#E8DDD0",
    "lDivider": "#D4C8B8",
    "lText": "#2A1F1A",
    "lText3": "#7D7068",
    "lText4": "#A09489",
    "lRose1": "#8B2252",
    "lRose2": "#722F37",
    "lGold1": "#7D5B38",
    "lGold2": "#9A7245",
    "lSage1": "#5A6B40",
    "lSage2": "#4A5934",
    "lType1": "#4A5670",
    "lTerra1": "#A03025"
  },
  "theme": {
    "primary": { "dark": "dRose1", "light": "lRose1" },
    "secondary": { "dark": "dType1", "light": "lType1" },
    "accent": { "dark": "dGold1", "light": "lGold1" },
    "error": { "dark": "dTerra1", "light": "lTerra1" },
    "warning": { "dark": "dGold1", "light": "lGold1" },
    "success": { "dark": "dSage1", "light": "lSage1" },
    "info": { "dark": "dType1", "light": "lType1" },
    "text": { "dark": "dText", "light": "lText" },
    "textMuted": { "dark": "dText3", "light": "lText3" },
    "background": { "dark": "dBg", "light": "lBg" },
    "backgroundPanel": { "dark": "dBgSoft", "light": "lBgSoft" },
    "backgroundElement": { "dark": "dBgMute", "light": "lBgMute" },
    "border": { "dark": "dDivider", "light": "lDivider" },
    "borderActive": { "dark": "dRose1", "light": "lRose1" },
    "borderSubtle": { "dark": "dDivider", "light": "lDivider" },
    "diffAdded": { "dark": "dSage1", "light": "lSage1" },
    "diffRemoved": { "dark": "dTerra1", "light": "lTerra1" },
    "diffContext": { "dark": "dBgSoft", "light": "lBgSoft" },
    "diffHunkHeader": { "dark": "dBgMute", "light": "lBgMute" },
    "diffHighlightAdded": { "dark": "dSage1", "light": "lSage1" },
    "diffHighlightRemoved": { "dark": "dTerra1", "light": "lTerra1" },
    "diffAddedBg": { "dark": "#8FA86E40", "light": "#5A6B4040" },
    "diffRemovedBg": { "dark": "#C4453640", "light": "#A0302540" },
    "diffContextBg": { "dark": "dBgSoft", "light": "lBgSoft" },
    "diffLineNumber": { "dark": "dText3", "light": "lText3" },
    "diffAddedLineNumberBg": { "dark": "#8FA86E20", "light": "#5A6B4020" },
    "diffRemovedLineNumberBg": { "dark": "#C4453620", "light": "#A0302520" },
    "markdownText": { "dark": "dText", "light": "lText" },
    "markdownHeading": { "dark": "dRose1", "light": "lRose1" },
    "markdownLink": { "dark": "dType1", "light": "lType1" },
    "markdownLinkText": { "dark": "dType1", "light": "lType1" },
    "markdownCode": { "dark": "dSage1", "light": "lSage1" },
    "markdownBlockQuote": { "dark": "dText3", "light": "lText3" },
    "markdownEmph": { "dark": "dGold1", "light": "lGold1" },
    "markdownStrong": { "dark": "dRose1", "light": "lRose1" },
    "markdownHorizontalRule": { "dark": "dText3", "light": "lText3" },
    "markdownListItem": { "dark": "dText", "light": "lText" },
    "markdownListEnumeration": { "dark": "dText3", "light": "lText3" },
    "markdownImage": { "dark": "dType1", "light": "lType1" },
    "markdownImageText": { "dark": "dType1", "light": "lType1" },
    "markdownCodeBlock": { "dark": "dSage1", "light": "lSage1" },
    "syntaxComment": { "dark": "dText4", "light": "lText4" },
    "syntaxKeyword": { "dark": "dRose1", "light": "lRose1" },
    "syntaxFunction": { "dark": "dGold1", "light": "lGold1" },
    "syntaxVariable": { "dark": "dText", "light": "lText" },
    "syntaxString": { "dark": "dSage1", "light": "lSage1" },
    "syntaxNumber": { "dark": "dGold1", "light": "lGold1" },
    "syntaxType": { "dark": "dType1", "light": "lType1" },
    "syntaxOperator": { "dark": "dText3", "light": "lText3" },
    "syntaxPunctuation": { "dark": "dText3", "light": "lText3" }
  }
}
