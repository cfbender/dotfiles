import os
import resource

def _xonsh_env_path_prepend(path):
    path = os.path.expanduser(path)
    if path not in $PATH:
        $PATH.insert(0, path)

def _xonsh_env_path_append(path):
    path = os.path.expanduser(path)
    if path not in $PATH:
        $PATH.append(path)

_xonsh_env_path_prepend('/opt/homebrew/bin')
_xonsh_env_path_append('/opt/homebrew/share/google-cloud-sdk/bin')
_xonsh_env_path_append('/usr/local/bin')
_xonsh_env_path_append('~/bin')
_xonsh_env_path_append('~/.cargo/bin')
_xonsh_env_path_append('~/.deno/bin')
_xonsh_env_path_append('~/go/bin')
_xonsh_env_path_append('~/.local/bin')
_xonsh_env_path_append('~/.cabal/bin')
_xonsh_env_path_append('~/.ghcup/bin')
_xonsh_env_path_append('~/Library/pnpm')
_xonsh_env_path_append('/opt/homebrew/opt/coreutils/libexec/gnubin')

$RIPGREP_CONFIG_PATH = os.path.expanduser('~/.ripgreprc')
$LANG = 'en_US.UTF-8'
$LANGUAGE = 'en_US.UTF-8'
$LC_ALL = 'en_US.UTF-8'
$CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense'
$OPENCODE_AGENT_SKILLS_SUPERPOWERS_MODE = 'true'
$PNPM_HOME = os.path.expanduser('~/Library/pnpm')

if not __xonsh__.env.get('OCX_PROFILE'):
{{- if .work }}
    $OCX_PROFILE = 'work-or'
{{- else }}
    $OCX_PROFILE = 'personal-zen'
{{- end }}

try:
    _xonsh_env_soft_nofile, _xonsh_env_hard_nofile = resource.getrlimit(resource.RLIMIT_NOFILE)
    resource.setrlimit(resource.RLIMIT_NOFILE, (min(max(_xonsh_env_soft_nofile, 4096), _xonsh_env_hard_nofile), _xonsh_env_hard_nofile))
except (OSError, ValueError):
    pass
