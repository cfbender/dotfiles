# Ported from dot_config/hygge/private_config.toml.tmpl and
# dot_config/hygge/profiles/personal-direct/config.toml.
#
# OMP profiles are full user-level config roots. This file repeats the common
# agent settings because profiles do not inherit from dot_omp/agent/config.yml.

setupVersion: 1

theme:
  dark: claret
  light: claret

compaction:
  thresholdPercent: 75

ask:
  notify: "on"
completion:
  notify: "off"

symbolPreset: "nerd"

tools:
  approvalMode: "yolo"
  approval:
    bash: "allow"
    edit: "allow"
    read: "allow"
    task: "allow"
    write: "allow"
    browser: "prompt"
    github: "prompt"
    web_search: "prompt"

defaultThinkingLevel: "high"
modelRoles:
  default: "openai/gpt-5.5:high"
  smol: "openai/gpt-5.4-mini"
  slow: "openai/gpt-5.5:xhigh"
  plan: "openai/gpt-5.5:high"
  task: "openai/gpt-5.5"
  advisor: "openai/gpt-5.5"
  title: "openai/gpt-5.4-mini"
  commit: "openai/gpt-5.5:off"
