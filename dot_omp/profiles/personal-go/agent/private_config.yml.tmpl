# Ported from dot_config/hygge/private_config.toml.tmpl and
# dot_config/hygge/profiles/personal-go/config.toml.
#
# OMP profiles are full user-level config roots. This file repeats the common
# agent settings because profiles do not inherit from dot_omp/agent/config.yml.

setupVersion: 1

theme:
  dark: claret
  light: claret

compaction:
  thresholdPercent: 75

ask:
  notify: "on"
completion:
  notify: "off"

symbolPreset: "nerd"

tools:
  approvalMode: "yolo"
  approval:
    bash: "allow"
    edit: "allow"
    read: "allow"
    task: "allow"
    write: "allow"
    browser: "prompt"
    github: "prompt"
    web_search: "prompt"

defaultThinkingLevel: "medium"
modelRoles:
  default: "opencode-go/deepseek-v4-pro:medium"
  smol: "opencode-go/deepseek-v4-flash"
  slow: "opencode-go/mimo-v2.5-pro:high"
  plan: "opencode-go/deepseek-v4-pro:medium"
  task: "opencode-go/deepseek-v4-pro"
  advisor: "opencode-go/deepseek-v4-pro"
  title: "opencode-go/deepseek-v4-flash"
  commit: "opencode-go/deepseek-v4-flash:off"
