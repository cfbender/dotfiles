# Ported from dot_config/hygge/private_config.toml.tmpl and
# dot_config/hygge/profiles/personal-or/config.toml.
#
# OMP profiles are full user-level config roots. This file repeats the common
# agent settings because profiles do not inherit from dot_omp/agent/config.yml.

setupVersion: 1

theme:
  dark: claret
  light: claret

compaction:
  thresholdPercent: 75

ask:
  notify: "on"
completion:
  notify: "off"

symbolPreset: "nerd"

tools:
  approvalMode: "yolo"
  approval:
    bash: "allow"
    edit: "allow"
    read: "allow"
    task: "allow"
    write: "allow"
    browser: "prompt"
    github: "prompt"
    web_search: "prompt"

defaultThinkingLevel: "medium"
modelRoles:
  default: "openrouter/anthropic/claude-sonnet-4.6:medium"
  smol: "openrouter/deepseek/deepseek-v4-flash"
  slow: "openrouter/openai/gpt-5.3-codex:high"
  plan: "openrouter/anthropic/claude-sonnet-4.6:medium"
  task: "openrouter/anthropic/claude-sonnet-4.6"
  advisor: "openrouter/openai/gpt-5.4"
  title: "openrouter/deepseek/deepseek-v4-flash"
  commit: "openrouter/anthropic/claude-haiku-4.5:off"
