# =============================================================================
# Tmux Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
set-option -g default-terminal "tmux-256color"
set-option -g default-shell {{ output "brew" "--prefix" | trim }}/bin/nu

# Vim key bindings
set-option -g mode-keys vi
set-option -g status-keys vi

# Mouse support
set-option -g mouse on

# Clipboard
set -g set-clipboard on

# No escape delay
set-option -g escape-time 0

# Focus events for vim integration
set-option -g focus-events on

# History
set-option -g history-limit 10000
set-option -g history-file ~/.tmux/tmuxhistory

# Activity monitoring (disabled)
set-option -g monitor-activity off
set-option -g visual-activity off

# Window/pane indexing starts at 1
set-option -g base-index 1
set-option -g pane-base-index 1

# Window management
set-option -g -w automatic-rename on
set-option -g renumber-windows on

# No bells
set-option -g bell-action none

# RGB color support
set-option -g -a terminal-overrides ",xterm-256color:Tc"

# Don't exit tmux when closing a session
set -g detach-on-destroy off

# -----------------------------------------------------------------------------
# Key Bindings
# -----------------------------------------------------------------------------

# Prefix key: C-a
unbind-key C-b
set-option -g prefix C-a
bind-key C-a send-prefix

# Reload configuration
bind-key r source-file ~/.tmux.conf \; display-message "~/.tmux.conf reloaded"

# Pane navigation (Alt + hjkl)
bind-key -n M-h select-pane -L
bind-key -n M-j select-pane -D
bind-key -n M-k select-pane -U
bind-key -n M-l select-pane -R

# Window navigation
unbind-key n
bind-key -n M-p previous-window
bind-key -n M-n next-window
bind-key -n M-1 select-window -t:1
bind-key -n M-2 select-window -t:2
bind-key -n M-3 select-window -t:3
bind-key -n M-4 select-window -t:4
bind-key -n M-5 select-window -t:5
bind-key -n M-6 select-window -t:6
bind-key -n M-7 select-window -t:7
bind-key -n M-8 select-window -t:8
bind-key -n M-9 select-window -t:9
bind-key -n M-0 select-window -t:10

# Split panes (with current path)
unbind-key '"'
unbind-key '%'
bind-key '-' split-window -v -c "#{pane_current_path}"
bind-key '\' split-window -h -c "#{pane_current_path}"
bind-key '_' split-window -fv -c "#{pane_current_path}"
bind-key '|' split-window -fh -c "#{pane_current_path}"

# Resize panes (Alt + Shift + hjkl)
bind-key -n M-H resize-pane -L 2
bind-key -n M-J resize-pane -D 1
bind-key -n M-K resize-pane -U 1
bind-key -n M-L resize-pane -R 2

# Toggle zoom
bind-key -n M-z resize-pane -Z

# Move panes
unbind-key '{'
unbind-key '}'
bind-key -r H swap-pane -U
bind-key -r L swap-pane -D

# Kill pane/window
bind-key x kill-pane
unbind-key '&'
bind-key X kill-window
bind-key K kill-window -a

# Swap windows
bind-key -r '<' swap-window -t -1
bind-key -r '>' swap-window -t +1

# Rally integration
bind s display-popup -E -w 80% -h 70% rally.sh

# -----------------------------------------------------------------------------
# Plugins
# -----------------------------------------------------------------------------
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-cpu'
set -g @plugin 'tmux-plugins/tmux-battery'

# Powerkit theme (Catppuccin Mocha)
set -g @plugin 'fabioluciano/tmux-powerkit'
set -g @powerkit_theme 'catppuccin'
set -g @powerkit_theme_variant 'mocha'
set -g @powerkit_plugin_datetime_format "%a %b %d - %I:%M %p"
set -g @powerkit_plugins 'datetime,cpu,memory,git,temperature,battery,loadvg'

# Initialize TPM (keep at bottom)
run -b '~/.tmux/plugins/tpm/tpm'
