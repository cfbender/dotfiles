Include /Users/cfb/.config/colima/ssh_config

# =============================================================================
# SSH Configuration
# =============================================================================

# Global defaults
Host *
	AddKeysToAgent yes
	IdentitiesOnly yes
	ServerAliveInterval 60
	ServerAliveCountMax 3
	# Forward locale so remote shell gets UTF-8 settings
	SendEnv LANG LC_*

# GitHub
Host github.com
	IdentityFile ~/.ssh/id_ed25519
