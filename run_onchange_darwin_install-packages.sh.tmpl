#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
  brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
  brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
  cask {{ . | quote }}
{{ end -}}
  EOF
{{ end -}}

if ! command -v rust-analyzer 2>&1 >/dev/null; then
  rustup component add rust-analyzer
fi
